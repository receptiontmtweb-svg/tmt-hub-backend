# ============================================================
# TMT HUB v14 — Variables d'environnement
# cp .env.example .env  →  remplir les valeurs
# Ne jamais committer .env
# ============================================================

# ── OBLIGATOIRES ─────────────────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Clé d'authentification des appels API (header X-TMT-Key)
TMT_MASTER_KEY=REMPLACER_64_CHARS_HEX_OBLIGATOIRE

# Clé de chiffrement AES-256-GCM des credentials marketplace
# DIFFÉRENTE de TMT_MASTER_KEY
CRED_ENCRYPTION_KEY=REMPLACER_64_CHARS_HEX_OBLIGATOIRE

# ── CORS ─────────────────────────────────────────────────────
# URL de votre frontend (MarketSync Pro hébergé)
ALLOWED_ORIGINS=https://votre-app.vercel.app,http://localhost:3000

# ── SANDBOXES ────────────────────────────────────────────────
# true en développement / test, false en PRODUCTION
AMZ_SANDBOX=true
OCTOPIA_SANDBOX=true

# ── SUPABASE (optionnel — mémoire volatile si absent) ─────────
# Créer un projet gratuit sur https://supabase.com
# Puis copier les valeurs depuis Settings > API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...    # anon key

# ── SERVEUR ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=INFO   # DEBUG | INFO | WARN | ERROR

# ── VERCEL (automatique si déployé sur Vercel) ────────────────
# VERCEL=1
